# Google AI Studio API key (apps/news-verification/)
gemini_api_key=your_key_here

# Hugging Face token — Read 권한 (apps/news-verification-open/)
HF_API_KEY=hf_your_token_here
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# 기본 모델 (유료 키 기준 가장 저렴: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# 회사망/백신이 HTTPS를 검사해 "fetch failed" 가 나면 1 로 설정 (로컬 개발용)
# GEMINI_INSECURE_SSL=1
